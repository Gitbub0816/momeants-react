# Copy to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────
# Supabase — https://app.supabase.com → project → Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# EAS Build — https://expo.dev after running `eas init`
EAS_PROJECT_ID=your-eas-project-id

# App variant — 'development' for local dev builds, 'preview' for TestFlight/internal track
# APP_VARIANT=development

# Optional: Sentry DSN for crash reporting
# EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# Sentry (get DSN from sentry.io after creating a React Native project)
EXPO_PUBLIC_SENTRY_DSN=
